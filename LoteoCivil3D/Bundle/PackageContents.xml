      ModuleName="./Contents/Win64/LoteoCivil3D.dll"
      AppDescription="Loteo Civil3D - Grading y Etiquetado"
      LoadOnAutoCADStartup="True"
      LoadOnCommandInvocation="True">
      <Commands>
        <Command Local="LOTEO_SETTINGS" Global="LOTEO_SETTINGS" />
        <Command Local="LOTEO_GRADER" Global="LOTEO_GRADER" />
        <Command Local="LOTEO_LABELER" Global="LOTEO_LABELER" />
        <Command Local="LOTEO_UPDATE" Global="LOTEO_UPDATE" />
        <Command Local="LOTEO_ABOUT" Global="LOTEO_ABOUT" />
        <Command Local="LOTEO_HELP" Global="LOTEO_HELP" />
      </Commands>
    </ComponentEntry>
  </Components>
</ApplicationPackage>
