<?xml version="1.0" encoding="utf-8"?>
<ApplicationPackage SchemaVersion="1.0"
  AutodeskProduct="AutoCAD"
  ProductType="Application"
  Name="Loteo Civil3D"
  AppVersion="1.0.0.0"
  Description="Herramientas de grading y etiquetado para loteos residenciales en Civil 3D."
